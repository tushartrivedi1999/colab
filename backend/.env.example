NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
DATABASE_URL=postgres://postgres:postgres@localhost:5432/heat_relief
DATABASE_SSL_ENABLED=false
JWT_SECRET=replace-with-a-random-32-char-or-longer-secret
JWT_EXPIRES_IN=1d
CORS_ORIGIN=http://localhost:3000
EMAIL_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
FORCE_HTTPS=false
GLOBAL_RATE_LIMIT_WINDOW_MS=900000
GLOBAL_RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
LOG_LEVEL=info
